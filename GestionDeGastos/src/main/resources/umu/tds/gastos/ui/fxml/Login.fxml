<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns="http://javafx.com/javafx/25"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="umu.tds.gastos.ui.controller.LoginController"
           style="-fx-background-color: linear-gradient(to bottom right, #1E3C72, #2A5298);">

    <children>

        <VBox alignment="CENTER"
              spacing="30"
              maxWidth="450"
              style="-fx-background-color: white;
                     -fx-background-radius: 20;
                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.25), 25, 0.3, 0, 8);">

            <padding>
                <Insets top="60" right="70" bottom="60" left="70"/>
            </padding>

            <children>

                <StackPane style="-fx-background-color: transparent;
                                  -fx-border-color: #2A5298;
                                  -fx-border-width: 2;
                                  -fx-border-radius: 50;
                                  -fx-min-width: 90;
                                  -fx-min-height: 90;
                                  -fx-max-width: 90;
                                  -fx-max-height: 90;">

                    <children>
                        <Label text="€"
                               style="-fx-text-fill: #2A5298;
                                      -fx-font-size: 36px;
                                      -fx-font-weight: bold;"/>
                    </children>
                </StackPane>

                <Label text="Gestión de Gastos"
                       style="-fx-font-size: 22px;
                              -fx-font-weight: bold;
                              -fx-text-fill: #1E3C72;"/>

                <Label text="Controla tus ingresos y gastos de forma sencilla"
                       wrapText="true"
                       style="-fx-text-fill: #666666;
                              -fx-alignment: center;
                              -fx-text-alignment: center;
                              -fx-font-size: 14px;"/>

                <Button fx:id="btnEntrar"
                        text="Entrar"
                        onAction="#entrar"
                        prefWidth="250"
                        prefHeight="50"
                        mnemonicParsing="false"
                        style="-fx-background-color: #2A5298;
                               -fx-text-fill: white;
                               -fx-font-size: 16px;
                               -fx-font-weight: bold;
                               -fx-background-radius: 10;
                               -fx-cursor: hand;"/>

                <Label text="Versión 1.0"
                       style="-fx-text-fill: #999999;
                              -fx-font-size: 11px;"/>

            </children>

        </VBox>

    </children>

</StackPane>
