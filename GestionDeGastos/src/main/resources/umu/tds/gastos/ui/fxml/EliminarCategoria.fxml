<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TitledPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<TitledPane text="Eliminar categoría"
            animated="false"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="umu.tds.gastos.ui.controller.EliminarCategoriaController">

    <content>

        <VBox spacing="20"
              style="-fx-background-color: #F5F7FA;"
              prefWidth="420">

            <padding>
                <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>

            <Label text="Eliminar categoría"
                   style="-fx-font-size: 20px;
                          -fx-font-weight: bold;
                          -fx-text-fill: #1E2A38;"/>

            <Label text="Selecciona la categoría que deseas eliminar."
                   wrapText="true"
                   style="-fx-text-fill: #666;"/>

            <Label text="Categoría"/>
            <ComboBox fx:id="comboCategoria" prefWidth="360" promptText="Seleccionar categoría"/>

            <HBox spacing="10" alignment="CENTER_RIGHT">
                <children>
                    <Button fx:id="btnCancelar"
                            text="Cancelar"
                            onAction="#cancelar"
                            style="-fx-background-color: transparent;
                                   -fx-border-color: #999;
                                   -fx-border-radius: 6;"/>

                    <Button fx:id="btnAceptar"
                            text="Eliminar"
                            onAction="#aceptar"
                            style="-fx-background-color: #C0392B;
                                   -fx-text-fill: white;
                                   -fx-background-radius: 6;"/>
                </children>
            </HBox>

        </VBox>

    </content>

</TitledPane>
