<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.TitledPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<TitledPane text="Importar gastos"
            animated="false"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="umu.tds.gastos.ui.controller.ImportarController">

    <content>

        <VBox spacing="20"
              style="-fx-background-color: #F5F7FA;"
              prefWidth="500">

            <padding>
                <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>

            <Label text="Importar gastos desde CSV"
                   style="-fx-font-size: 20px;
                          -fx-font-weight: bold;
                          -fx-text-fill: #1E2A38;"/>

            <Label text="Selecciona la cuenta destino y el archivo CSV a importar."
                   wrapText="true"
                   style="-fx-text-fill: #666;"/>

            <Label text="Cuenta destino"/>
            <ComboBox fx:id="comboCuenta" prefWidth="400" promptText="Seleccionar cuenta"/>

            <Label text="Archivo CSV"/>
            <HBox spacing="10">
                <children>
                    <TextField fx:id="archivoField" editable="false" HBox.hgrow="ALWAYS" promptText="Ningún archivo seleccionado"/>
                    <Button fx:id="btnSeleccionar"
                            text="Seleccionar..."
                            onAction="#seleccionarArchivo"
                            prefHeight="31"
                            style="-fx-background-color: #3D5A80;
                                   -fx-text-fill: white;
                                   -fx-background-radius: 6;"/>
                </children>
            </HBox>

            <HBox spacing="10" alignment="CENTER_RIGHT">
                <children>
                    <Button fx:id="btnCancelar"
                            text="Cancelar"
                            onAction="#cancelar"
                            style="-fx-background-color: transparent;
                                   -fx-border-color: #999;
                                   -fx-border-radius: 6;"/>

                    <Button fx:id="btnAceptar"
                            text="Importar"
                            onAction="#aceptar"
                            style="-fx-background-color: #3D5A80;
                                   -fx-text-fill: white;
                                   -fx-background-radius: 6;"/>
                </children>
            </HBox>

        </VBox>

    </content>

</TitledPane>
