<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.TitledPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<TitledPane text="Crear límite"
            animated="false"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="umu.tds.gastos.ui.controller.AddAlertaController">

    <content>

        <VBox spacing="20"
              style="-fx-background-color: #F5F7FA;"
              prefWidth="460">

            <padding>
                <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>

            <Label text="Nuevo límite"
                   style="-fx-font-size: 20px;
                          -fx-font-weight: bold;
                          -fx-text-fill: #1E2A38;"/>

            <Label text="Define un límite de gasto para controlar tus finanzas."
                   wrapText="true"
                   style="-fx-text-fill: #666;"/>

            <Label text="Cantidad límite (€)"/>
            <TextField fx:id="cantidadAlerta"
                       promptText="Ej: 200"/>

            <Label text="Tipo"/>
            <HBox spacing="20">
                <children>
                    <CheckBox fx:id="chboxSemanal" text="Semanal"/>
                    <CheckBox fx:id="chboxMensual" text="Mensual"/>
                </children>
            </HBox>

            <Label text="Categoría (opcional)"/>
            <ComboBox fx:id="comboCategoria" prefWidth="300" promptText="Todas las categorías"/>

            <HBox spacing="10" alignment="CENTER_RIGHT">
                <children>
                    <Button fx:id="btnCancelar"
                            text="Cancelar"
                            onAction="#cancelar"
                            style="-fx-background-color: transparent;
                                   -fx-border-color: #999;
                                   -fx-border-radius: 6;"/>

                    <Button fx:id="btnAceptar"
                            text="Crear límite"
                            onAction="#aceptar"
                            style="-fx-background-color: #3D5A80;
                                   -fx-text-fill: white;
                                   -fx-background-radius: 6;"/>
                </children>
            </HBox>

        </VBox>

    </content>

</TitledPane>
