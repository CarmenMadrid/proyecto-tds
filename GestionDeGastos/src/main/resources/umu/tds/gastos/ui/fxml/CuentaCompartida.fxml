<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<TitledPane text="Crear cuenta compartida"
            animated="false"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="umu.tds.gastos.ui.controller.CuentaCompartidaController">

    <content>

        <VBox spacing="20"
              style="-fx-background-color: #F5F7FA;"
              prefWidth="760">

            <padding>
                <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>

            <Label text="Nueva cuenta compartida"
                   style="-fx-font-size: 20px;
                          -fx-font-weight: bold;
                          -fx-text-fill: #1E2A38;"/>

            <Label text="Crea una cuenta con reparto equitativo o personalizado entre varios participantes."
                   wrapText="true"
                   style="-fx-text-fill: #666;"/>

            <Separator/>

            <HBox spacing="30">

                <VBox spacing="16" prefWidth="315" HBox.hgrow="NEVER">

                    <Label text="Nombre de la cuenta"/>
                    <TextField fx:id="nombreCuentaCompartida"
                               promptText="Ej: Piso compartido"/>

                    <Separator/>

                    <Label text="Método de reparto"
                           style="-fx-font-weight: bold;
                                  -fx-font-size: 14px;
                                  -fx-text-fill: #1E2A38;"/>

                    <HBox spacing="24">
                        <RadioButton fx:id="rbEquitativo"
                                     text="Equitativo"
                                     selected="true">
                            <toggleGroup>
                                <ToggleGroup fx:id="grupoReparto"/>
                            </toggleGroup>
                        </RadioButton>
                        <RadioButton fx:id="rbPersonalizado"
                                     text="Personalizado"
                                     toggleGroup="$grupoReparto"/>
                    </HBox>

                    <Separator/>

                    <VBox spacing="4"
                          style="-fx-background-color: #EDF2F7;
                                 -fx-background-radius: 6;
                                 -fx-padding: 12;">

                        <Label text="Resumen"
                               style="-fx-font-weight: bold;
                                      -fx-font-size: 13px;
                                      -fx-text-fill: #1E2A38;"/>

                        <Label fx:id="lblResumenParticipantes"
                               text="Participantes: 0"
                               style="-fx-text-fill: #555;"/>

                        <Label fx:id="lblResumenMetodo"
                               text="Método: Equitativo"
                               style="-fx-text-fill: #555;"/>

                        <Label fx:id="lblResumenTotal"
                               text="Reparto total: —"
                               style="-fx-text-fill: #555;"/>

                    </VBox>

                </VBox>

                <VBox spacing="12" HBox.hgrow="ALWAYS">

                    <Label text="Participantes"
                           style="-fx-font-weight: bold;
                                  -fx-font-size: 14px;
                                  -fx-text-fill: #1E2A38;"/>

                    <TableView fx:id="tablaPersonas"
                               prefHeight="220"
                               VBox.vgrow="ALWAYS"
                               tableMenuButtonVisible="false">
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                        </columnResizePolicy>

                        <columns>
                            <TableColumn fx:id="columnaNombre"
                                         text="Nombre"
                                         prefWidth="160"
                                         editable="false"/>

                            <TableColumn fx:id="columnaPorcentaje"
                                         text="Porcentaje (%)"
                                         prefWidth="120"/>

                            <TableColumn fx:id="columnaAccion"
                                         text=""
                                         prefWidth="50"/>
                        </columns>

                    </TableView>

                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <TextField fx:id="nombrePersona"
                                   promptText="Nombre del participante"
                                   HBox.hgrow="ALWAYS"/>
                        <Button fx:id="btnAddPersona"
                                text="Añadir participante"
                                onAction="#addPersona"
                                style="-fx-background-color: #3D5A80;
                                       -fx-text-fill: white;
                                       -fx-background-radius: 6;"/>
                    </HBox>

                </VBox>

            </HBox>

            <Separator/>

            <HBox spacing="10" alignment="CENTER_RIGHT">

                <Button fx:id="btnCancelar"
                        text="Cancelar"
                        onAction="#cancelar"
                        style="-fx-background-color: transparent;
                               -fx-border-color: #999;
                               -fx-border-radius: 6;"/>

                <Button fx:id="btnAceptar"
                        text="Crear cuenta"
                        onAction="#aceptar"
                        style="-fx-background-color: #3D5A80;
                               -fx-text-fill: white;
                               -fx-background-radius: 6;"/>

            </HBox>

        </VBox>

    </content>

</TitledPane>
