<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<TitledPane text="Crear cuenta compartida"
            animated="false"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="umu.tds.gastos.ui.controller.CuentaCompartidaController">

    <content>

        <VBox spacing="20"
              style="-fx-background-color: #F5F7FA;"
              prefWidth="700">

            <padding>
                <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>

            <!-- TÍTULO -->
            <Label text="Nueva cuenta compartida"
                   style="-fx-font-size: 20px;
                          -fx-font-weight: bold;
                          -fx-text-fill: #1E2A38;"/>

            <Label text="Define el nombre y añade los participantes con su porcentaje de gasto."
                   wrapText="true"
                   style="-fx-text-fill: #666;"/>

            <!-- FORMULARIO PRINCIPAL -->
            <HBox spacing="20">

                <!-- IZQUIERDA: FORMULARIO -->
                <VBox spacing="12" prefWidth="300">

                    <Label text="Nombre de la cuenta"/>
                    <TextField fx:id="nombreCuentaCompartida"
                               promptText="Ej: Viaje a París"/>

                    <Separator/>

                    <Label text="Añadir persona"
                           style="-fx-font-weight: bold;"/>

                    <TextField fx:id="nombrePersona"
                               promptText="Nombre de la persona"/>

                    <TextField fx:id="porcentajePersona"
                               promptText="Porcentaje (%)"/>

                    <CheckBox fx:id="btnPorcentaje"
                              text="Reparto no equitativo"/>

                    <Button fx:id="btnAddPersona"
                            text="Añadir persona"
                            onAction="#addPersona"
                            prefWidth="200"
                            style="-fx-background-color: #3D5A80;
                                   -fx-text-fill: white;
                                   -fx-background-radius: 8;"/>
                </VBox>

                <!-- DERECHA: TABLA -->
                <VBox spacing="10" VBox.vgrow="ALWAYS">

                    <Label text="Participantes"
                           style="-fx-font-weight: bold;
                                  -fx-font-size: 14px;"/>

                    <TableView fx:id="tablaPersonasCuenta"
                               VBox.vgrow="ALWAYS">

                        <columns>
                            <TableColumn fx:id="columnaNombre"
                                         text="Nombre"
                                         prefWidth="180"/>

                            <TableColumn fx:id="columnaPorcentaje"
                                         text="Porcentaje (%)"
                                         prefWidth="180"/>
                        </columns>

                    </TableView>

                </VBox>

            </HBox>

            <!-- BOTONES ACCIÓN -->
            <HBox spacing="10" alignment="CENTER_RIGHT">

                <Button fx:id="btnCancelar"
                        text="Cancelar"
                        onAction="#cancelar"
                        style="-fx-background-color: transparent;
                               -fx-border-color: #999;
                               -fx-border-radius: 6;"/>

                <Button fx:id="btnAceptar"
                        text="Crear cuenta"
                        onAction="#aceptar"
                        style="-fx-background-color: #3D5A80;
                               -fx-text-fill: white;
                               -fx-background-radius: 6;"/>

            </HBox>

        </VBox>

    </content>

</TitledPane>