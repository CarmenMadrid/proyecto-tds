<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TitledPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<TitledPane text="Confirmar"
            animated="false"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="umu.tds.gastos.ui.controller.ConfirmacionController">

    <content>

        <VBox spacing="20"
              style="-fx-background-color: #F5F7FA;"
              prefWidth="440">

            <padding>
                <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>

            <Label text="Confirmar acción"
                   style="-fx-font-size: 20px;
                          -fx-font-weight: bold;
                          -fx-text-fill: #1E2A38;"/>

            <Label fx:id="mensajeLabel"
                   wrapText="true"
                   style="-fx-text-fill: #333;"/>

            <HBox spacing="10" alignment="CENTER_RIGHT">
                <children>
                    <Button fx:id="btnCancelar"
                            text="Cancelar"
                            onAction="#cancelar"
                            style="-fx-background-color: transparent;
                                   -fx-border-color: #999;
                                   -fx-border-radius: 6;"/>

                    <Button fx:id="btnAceptar"
                            text="Aceptar"
                            onAction="#aceptar"
                            style="-fx-background-color: #C0392B;
                                   -fx-text-fill: white;
                                   -fx-background-radius: 6;"/>
                </children>
            </HBox>

        </VBox>

    </content>

</TitledPane>
